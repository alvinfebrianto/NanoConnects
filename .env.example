# Supabase Configuration (frontend)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Configuration (backend fallback; can match VITE_* values)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# AI Configuration (backend only - Node Functions)
# Comma-separated for multiple keys (auto-rotation supported)
AI_API_KEYS=your_openrouter_api_key_1,your_openrouter_api_key_2
AI_MODEL=openrouter/free

# Heartbeat endpoint secret (used by EasyCron to prevent Supabase free tier pause)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HEARTBEAT_SECRET=your_random_secret_hex
